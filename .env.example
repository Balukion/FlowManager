# ─── Aplicação ─────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ─── Banco de Dados ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flowmanager
DATABASE_TEST_URL=postgresql://postgres:postgres@localhost:5432/flowmanager_test

# ─── JWT ───────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres — gerar com: openssl rand -hex 32
JWT_SECRET=change_me_with_at_least_32_characters_long_secret
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
TOKEN_SECRET=change_me_with_at_least_32_characters_long_secret_2

# ─── Tokens ────────────────────────────────────────────────────────────────────
INVITATION_TOKEN_EXPIRES_HOURS=72
EMAIL_VERIFICATION_TOKEN_EXPIRES_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRES_HOURS=1

# ─── Segurança ─────────────────────────────────────────────────────────────────
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=30
ALLOWED_ORIGINS=http://localhost:3000

# ─── AWS S3 ────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=sa-east-1
AWS_S3_BUCKET_NAME=flowmanager-uploads
S3_MAX_AVATAR_SIZE_MB=2
S3_MAX_LOGO_SIZE_MB=5

# ─── Resend ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=FlowManager

# ─── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://example@sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://example@sentry.io/0

# ─── Paginação ─────────────────────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ─── Jobs (cron) ───────────────────────────────────────────────────────────────
CRON_CLEANUP=0 2 * * *
CRON_DEADLINE_REMINDERS=0 8 * * *
CRON_RETRY_NOTIFICATIONS=0 * * * *


